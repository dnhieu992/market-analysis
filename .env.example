NODE_ENV=development
PORT=3000
DATABASE_URL="mysql://root:root@127.0.0.1:3306/market_analysis"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3001"
SESSION_COOKIE_NAME="market_analysis_session"
SESSION_TTL_DAYS="7"
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"
# Daily analysis is routed through the backend LLM gateway.
LLM_PROVIDER="claude"
CLAUDE_API_KEY="your-claude-api-key"
# Sonnet is the default; raw Claude model IDs also work.
CLAUDE_MODEL="sonnet"
CLAUDE_TIMEOUT_MS="60000"
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-telegram-chat-id"
BINANCE_BASE_URL="https://api.binance.com"
TRACKED_SYMBOLS="BTCUSDT,ETHUSDT"
ANALYSIS_TIMEFRAME="4h"
ANALYSIS_CRON="1 0 */4 * * *"
LOG_LEVEL="debug"
MANUAL_ANALYSIS_TRIGGER_ENABLED="false"
# Optional: CoinGecko API key for small-cap radar sync (demo key = free at coingecko.com/api/pricing, higher rate limits)
COINGECKO_API_KEY=""

# --- Bitget live trading (day-trading bot, Phase 2) ---
# Real futures account. API permissions: Trade (ON), Withdraw (OFF). Whitelist the server IP.
# Keep LIVE_TRADING_ENABLED=false until Phase 2 (idempotency + reconciliation) is implemented.
BITGET_API_KEY=""
BITGET_API_SECRET=""
BITGET_API_PASSPHRASE=""
# usdt-futures = real, susdt-futures = demo
BITGET_PRODUCT_TYPE="usdt-futures"
# Leverage for LIVE positions (isolated). Size is risk-based, independent of this.
BITGET_LEVERAGE="10"
LIVE_TRADING_ENABLED="false"

# --- Cloudflare R2 image storage (POST /uploads/images) ---
# S3-compatible object storage. If any of these are unset, R2 uploads return a
# clear 503 and the rest of the app keeps running.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Public bucket/custom-domain base URL, e.g. https://images.example.com (no trailing slash)
R2_PUBLIC_URL=""

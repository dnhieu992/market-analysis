NODE_ENV=development
PORT=3000
DATABASE_URL="mysql://root:root@127.0.0.1:3306/market_analysis"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3001"
SESSION_COOKIE_NAME="market_analysis_session"
SESSION_TTL_DAYS="7"
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"
# Daily analysis is routed through the backend LLM gateway.
LLM_PROVIDER="claude"
CLAUDE_API_KEY="your-claude-api-key"
# Sonnet is the default; raw Claude model IDs also work.
CLAUDE_MODEL="sonnet"
CLAUDE_TIMEOUT_MS="60000"
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-telegram-chat-id"
BINANCE_BASE_URL="https://api.binance.com"
TRACKED_SYMBOLS="BTCUSDT,ETHUSDT"
ANALYSIS_TIMEFRAME="4h"
ANALYSIS_CRON="1 0 */4 * * *"
LOG_LEVEL="debug"
MANUAL_ANALYSIS_TRIGGER_ENABLED="false"

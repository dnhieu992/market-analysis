generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AnalysisRun {
  id               String            @id @default(cuid())
  symbol           String
  timeframe        String
  candleOpenTime   DateTime
  candleCloseTime  DateTime
  priceOpen        Float
  priceHigh        Float
  priceLow         Float
  priceClose       Float
  rawIndicatorsJson String           @db.Text
  llmInputJson     String            @db.Text
  llmOutputJson    String            @db.Text
  status           String
  errorMessage     String?           @db.Text
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  signal           Signal?
  telegramLogs     TelegramMessageLog[]

  @@unique([symbol, timeframe, candleCloseTime])
  @@index([symbol, timeframe, candleCloseTime])
}

model Signal {
  id                   String    @id @default(cuid())
  analysisRunId        String    @unique
  symbol               String
  timeframe            String
  trend                String
  bias                 String
  confidence           Int
  summary              String    @db.Text
  supportLevelsJson    String    @db.Text
  resistanceLevelsJson String    @db.Text
  invalidation         String    @db.Text
  bullishScenario      String    @db.Text
  bearishScenario      String    @db.Text
  createdAt            DateTime  @default(now())
  analysisRun          AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  orders               Order[]

  @@index([symbol, timeframe, createdAt])
}

model Order {
  id         String      @id @default(cuid())
  signalId   String?
  source     String
  symbol     String
  side       String
  entryPrice Float
  stopLoss   Float?
  takeProfit Float?
  quantity   Float?
  leverage   Float?
  exchange   String?
  broker     String?
  orderType  String?
  status     String
  openedAt   DateTime
  closedAt   DateTime?
  closePrice Float?
  pnl        Float?
  note       String?     @db.Text
  images     Json        @default("[]")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  signal     Signal?     @relation(fields: [signalId], references: [id], onDelete: SetNull)

  @@index([symbol, status, openedAt])
}

// A daily trading journal entry — freeform Markdown notes (analysis + emotions) plus
// trade-model images and freeform tags. One entry per calendar day (upserted by `date`).
// Kept as a corpus to later fine-tune an LLM "clone" of the trader and review discipline.
model TradingJournalEntry {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  content   String   @db.LongText
  images    Json     @default("[]") // string[] of Cloudflare R2 image URLs
  tags      Json     @default("[]") // string[] of freeform tags
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  revisions TradingJournalRevision[]

  @@map("trading_journal_entries")
}

/// Snapshot of a day's journal as it looked right after one save — the intra-day history.
model TradingJournalRevision {
  id        String   @id @default(cuid())
  entryId   String
  content   String   @db.LongText
  images    Json     @default("[]") // string[] of Cloudflare R2 image URLs
  tags      Json     @default("[]") // string[] of freeform tags
  createdAt DateTime @default(now())
  entry     TradingJournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId, createdAt])
  @@map("trading_journal_revisions")
}

model TelegramMessageLog {
  id            String              @id @default(cuid())
  analysisRunId String?
  chatId        String
  messageType   String
  content       String              @db.Text
  success       Boolean
  errorMessage  String?             @db.Text
  sentAt        DateTime
  createdAt     DateTime            @default(now())
  analysisRun   AnalysisRun?        @relation(fields: [analysisRunId], references: [id], onDelete: SetNull)
}

model DailyAnalysis {
  id        String   @id @default(cuid())
  symbol    String
  date      DateTime @db.Date
  status    String   @default("WAIT")
  d1Trend   String?
  h4Trend   String?
  d1S1      Float?
  d1S2      Float?
  d1R1      Float?
  d1R2      Float?
  h4S1      Float?
  h4S2      Float?
  h4R1      Float?
  h4R2      Float?
  llmProvider String?
  llmModel   String?
  aiOutputJson String @db.Text
  pipelineDebugJson String? @db.LongText
  summary   String   @db.Text
  feedbackScore Int?
  feedbackNote  String? @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([symbol, date])
  @@index([symbol, date])
}

model TrackedSetup {
  id                String   @id @default(cuid())
  dailyAnalysisId   String
  symbol            String
  planDate          DateTime @db.Date
  slot              String   // "primary" | "secondary"
  direction         String   // "long" | "short"
  entryLow          Float
  entryHigh         Float
  stopLoss          Float
  takeProfit1       Float?
  takeProfit2       Float?
  rawJson           String   @db.Text
  status            String   @default("PENDING") // PENDING|ENTERED|TP1_HIT|TP2_HIT|SL_HIT|INVALID|EXPIRED
  enteredAt         DateTime?
  tp1HitAt          DateTime?
  tp2HitAt          DateTime?
  slHitAt           DateTime?
  closedAt          DateTime?
  invalidatedReason String?  @db.Text
  notes             String?  @db.Text
  lastCheckedAt     DateTime?
  lastPrice         Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([dailyAnalysisId])
  @@index([symbol, planDate])
  @@index([status])
}

model Settings {
  id               String   @id @default("singleton")
  name             String
  trackingSymbols  Json     @default("[]")
  utbotWatchlist   Json     @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("settings")
}

model BackTestResult {
  id             String   @id @default(cuid())
  strategy       String
  symbol         String
  timeframe      String
  fromDate       DateTime
  toDate         DateTime
  totalTrades    Int
  winRate        Float
  totalPnl       Float
  maxDrawdown    Float
  sharpeRatio    Float?
  volume         Float    @default(1000)
  tradesJson     String   @db.LongText
  parametersJson String   @db.Text
  status         String
  errorMessage   String?  @db.Text
  createdAt      DateTime @default(now())

  @@index([strategy, symbol, createdAt])
}

model TradingStrategy {
  id             String   @id @default(uuid()) @db.Char(36)
  name           String
  content        String   @db.Text
  imageReference Json     @default("[]")
  version        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([name])
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  name                String
  symbolsTracking     Json                 @default("[]")
  dailySignalWatchlist Json                @default("[]")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  sessions            Session[]
  portfolios          Portfolio[]
  conversations       Conversation[]
  @@map("users")
}

model Conversation {
  id        String                @id @default(uuid()) @db.Char(36)
  userId    String
  skillId   String?               @db.VarChar(50)
  title     String                @db.VarChar(200)
  metadata  Json?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ConversationMessage[]

  @@index([userId])
  @@map("conversations")
}

model ConversationMessage {
  id             String       @id @default(uuid()) @db.Char(36)
  conversationId String       @db.Char(36)
  role           String       @db.VarChar(20)
  content        String       @db.Text
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("conversation_messages")
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("sessions")
}

model Portfolio {
  id           String            @id @default(uuid()) @db.Char(36)
  userId       String
  name         String            @db.VarChar(100)
  description  String?           @db.Text
  totalCapital Decimal?          @db.Decimal(20, 2)
  createdAt    DateTime          @default(now())
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions CoinTransaction[]
  holdings     Holding[]
  pnlHistory   PnlHistory[]
  @@index([userId])
  @@map("portfolios")
}

model CoinTransaction {
  id           String    @id @default(uuid()) @db.Char(36)
  portfolioId  String    @db.Char(36)
  coinId       String    @db.VarChar(50)
  type         String    @db.VarChar(10)
  price        Decimal   @db.Decimal(20, 8)
  amount       Decimal   @db.Decimal(20, 8)
  totalValue   Decimal   @db.Decimal(20, 8)
  fee          Decimal   @default(0) @db.Decimal(20, 8)
  note         String?   @db.Text
  images       Json      @default("[]")
  transactedAt DateTime
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
  portfolio    Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, coinId])
  @@index([transactedAt(sort: Desc)])
  @@map("transactions")
}

model Holding {
  id          String    @id @default(uuid()) @db.Char(36)
  portfolioId String    @db.Char(36)
  coinId      String    @db.VarChar(50)
  totalAmount Decimal   @db.Decimal(20, 8)
  totalCost   Decimal   @db.Decimal(20, 8)
  avgCost     Decimal   @db.Decimal(20, 8)
  realizedPnl Decimal   @default(0) @db.Decimal(20, 8)
  note        String?   @db.Text
  updatedAt   DateTime  @updatedAt
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, coinId])
  @@index([portfolioId])
  @@map("holdings")
}

model PnlHistory {
  id            String    @id @default(uuid()) @db.Char(36)
  portfolioId   String    @db.Char(36)
  coinId        String?   @db.VarChar(50)
  date          DateTime  @db.Date
  realizedPnl   Decimal   @db.Decimal(20, 8)
  unrealizedPnl Decimal   @db.Decimal(20, 8)
  totalValue    Decimal   @db.Decimal(20, 8)
  portfolio     Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, coinId, date])
  @@index([portfolioId, date(sort: Desc)])
  @@map("pnl_history")
}

model TrackingCoin {
  id              String                  @id @default(cuid())
  symbol          String                  @unique @db.VarChar(30)
  name            String                  @default("") @db.VarChar(100)
  marketCap       Float?
  addedAt         DateTime                @default(now())
  swingMaxLoss    Float?
  swingMinRR      Float?
  daytradeMaxLoss Float?
  daytradeMinRR   Float?
  dcaMaxLayers    Int?
  signals         TrackingCoinSignal[]
  signalHistory   TrackingCoinSignalHistory[]
  journals        TrackingCoinJournal[]
  orders          TrackingCoinOrder[]
  dcaBuys         TrackingCoinDcaBuy[]

  @@map("tracking_coins")
}

model TrackingCoinDcaBuy {
  id            String       @id @default(cuid())
  coinId        String
  price         Float
  usd           Float
  // How the layer was entered: "SIGNAL" (bought while dcaZone=GOM) vs "FOMO" (any other zone).
  entryMode     String?      @db.VarChar(8)
  boughtAt      DateTime     @default(now())
  createdAt     DateTime     @default(now())
  // Two-way sync with the portfolio: each DCA layer mirrors a CoinTransaction (BUY).
  portfolioId   String?      @db.Char(36)
  transactionId String?      @db.Char(36)
  coin          TrackingCoin @relation(fields: [coinId], references: [id], onDelete: Cascade)

  @@index([coinId, boughtAt(sort: Asc)])
  @@index([transactionId])
  @@map("tracking_coin_dca_buys")
}

model TrackingCoinOrder {
  id          String       @id @default(cuid())
  coinId      String
  date        DateTime     @db.Date
  type        String       @db.VarChar(15)
  side        String       @db.VarChar(5)
  entryLow    Float
  entryHigh   Float
  tp1         Float
  tp2         Float?
  sl          Float
  rrRatio       Float
  rationale     String       @db.Text
  notes         String?      @db.Text
  positionSize  Float?
  positionValue Float?
  activated     Boolean?
  outcome       String?      @db.VarChar(10)
  evaluatedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  coin        TrackingCoin @relation(fields: [coinId], references: [id], onDelete: Cascade)

  @@unique([coinId, date, type])
  @@index([coinId, date(sort: Desc)])
  @@map("tracking_coin_orders")
}

model TrackingCoinJournal {
  id        String       @id @default(cuid())
  coinId    String
  date      DateTime     @db.Date
  content   String       @db.LongText
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  coin      TrackingCoin @relation(fields: [coinId], references: [id], onDelete: Cascade)

  @@unique([coinId, date])
  @@index([coinId, date(sort: Desc)])
  @@map("tracking_coin_journals")
}

model TrackingCoinSignal {
  id             String       @id @default(cuid())
  coinId         String
  date           DateTime     @db.Date
  rsi            Float?
  volMultiplier  Float?
  ema34Above     Boolean      @default(false)
  ema89Above     Boolean      @default(false)
  ema200Above    Boolean      @default(false)
  stage          String       @default("Quiet") @db.VarChar(20)
  signalScore    Int          @default(0)
  entryScore     Int          @default(0)
  dcaScore       Int          @default(0)
  extPct         Float?
  low20Pct       Float?
  sparklineJson  String       @db.Text
  weekTrend      String       @default("Neutral") @db.VarChar(15)
  trend          String       @default("Neutral") @db.VarChar(15)
  h4Trend        String       @default("Neutral") @db.VarChar(15)
  m30Trend       String       @default("Neutral") @db.VarChar(15)
  swingStructure String       @default("Mixed") @db.VarChar(10)
  longScore      Float?
  shortScore     Float?
  utBotW1Bullish  Boolean?
  utBotD1Bullish  Boolean?
  utBotH4Bullish  Boolean?
  wEma34Above     Boolean?
  wEma89Above     Boolean?
  wEma200Above    Boolean?
  wRsi            Float?
  wVolMultiplier  Float?
  h4Ema34Above    Boolean?
  h4Ema89Above    Boolean?
  h4Ema200Above   Boolean?
  h4Rsi           Float?
  h4VolMultiplier Float?
  // M30 timeframe — display-only signal (not used in any scoring/logic).
  utBotM30Bullish  Boolean?
  m30Ema34Above    Boolean?
  m30Ema89Above    Boolean?
  m30Ema200Above   Boolean?
  m30Rsi           Float?
  m30VolMultiplier Float?
  // Accumulation-zone DCA signal (spot, no SL) — gated by dcaScore survival filter.
  accZone         String?      @db.VarChar(5)
  accDrawdownPct  Float?
  accBaseWidthPct Float?
  accInBase       Boolean?
  accGatePassed   Boolean?
  accBaseLow      Float?
  scannedAt       DateTime     @default(now())
  coin           TrackingCoin @relation(fields: [coinId], references: [id], onDelete: Cascade)

  @@unique([coinId, date])
  @@index([date, signalScore(sort: Desc)])
  @@map("tracking_coin_signals")
}

// Append-only change log of the DCA signal. A new row is written only when the
// DCA action zone (GOM/CHO/CHOT) OR the quality bucket (safe/ok/risky/avoid)
// differs from the most recent row for the coin — so this is a compact history
// of meaningful state changes, not every 4-hour scan.
model TrackingCoinSignalHistory {
  id         String       @id @default(cuid())
  coinId     String
  dcaScore   Int
  dcaZone    String?      @db.VarChar(5)
  dcaBucket  String       @db.VarChar(6)
  trend      String       @default("Neutral") @db.VarChar(15)
  weekTrend  String       @default("Neutral") @db.VarChar(15)
  h4Trend    String       @default("Neutral") @db.VarChar(15)
  rsi        Float?
  extPct     Float?
  price      Float?
  // Daily LLM (Haiku) review of an OPEN holding — null on plain change-log rows.
  entryMode  String?      @db.VarChar(8)
  avgEntry   Float?
  pnlPct     Float?
  llmVerdict String?      @db.VarChar(12)
  llmReview  String?      @db.Text
  llmModel   String?      @db.VarChar(40)
  scannedAt  DateTime     @default(now())
  coin       TrackingCoin @relation(fields: [coinId], references: [id], onDelete: Cascade)

  @@index([coinId, scannedAt(sort: Desc)])
  @@map("tracking_coin_signal_history")
}

model DayTradingSignal {
  id          String    @id @default(cuid())
  symbol      String    @db.VarChar(20)
  setupType   String    @db.VarChar(30)
  direction   String    @db.VarChar(5)
  entryPrice  Float
  stopLoss    Float
  takeProfit  Float
  rrRatio       Float     @default(2.0)
  riskAmount    Float     @default(2)
  quantity      Float?
  positionValue Float?
  status        String    @db.VarChar(20)
  mode          String    @default("PAPER") @db.VarChar(10)
  /// Bitget order id returned when a LIVE order is placed; null in PAPER mode.
  /// Used by reconciliation and to read the real fill price/PnL from the broker.
  brokerOrderId String?   @db.VarChar(64)
  breakEvenMoved Boolean  @default(false)
  closedPrice   Float?
  closedAt      DateTime?
  pnlUsd        Float?
  setupJson     String    @db.Text
  note          String?   @db.Text
  detectedAt  DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([symbol, status, detectedAt])
  @@map("day_trading_signals")
}

model DayTradingSettings {
  id              String   @id @default("singleton")
  riskPerTrade    Float    @default(2)
  minRR           Float    @default(2)
  maxTradesPerDay Int      @default(5)
  maxLossesPerDay Int      @default(2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("day_trading_settings")
}

/// Append-only audit trail of important day-trading bot actions. Survives pm2
/// log rotation so we can reconstruct *why* the bot entered/closed a trade.
model DayTradingActionLog {
  id        String   @id @default(cuid())
  /// SCAN_START, SETUP_DETECTED, SETUP_SKIPPED, ORDER_PLACED, ORDER_FAILED,
  /// BE_MOVED, CLOSED, MANUAL_CLOSE, RETRY, RECONCILE_FIX, …
  action    String   @db.VarChar(40)
  /// FK to the related DayTradingSignal when applicable (no relation constraint
  /// so a log row outlives any signal cleanup).
  signalId  String?  @db.VarChar(30)
  symbol    String?  @db.VarChar(20)
  /// Short human-readable summary for quick scanning.
  message   String   @db.Text
  /// Optional structured context (prices, error, attempt count) as JSON.
  detailJson String? @db.Text
  createdAt DateTime @default(now())

  @@index([signalId, createdAt])
  @@index([action, createdAt])
  @@map("day_trading_action_logs")
}

/// "Long Signal" strategy — LONG-only intraday FOMO gated by the M30 UTBot trend.
/// Each day at entryHour UTC, if the M30 UTBot trend is bull for a symbol, open a
/// LONG with a +tpPct take-profit and a wide catastrophe stop; force-close at
/// exitHour UTC if neither fired. Fixed notional per coin, no compounding.
model LongSignal {
  id            String    @id @default(cuid())
  symbol        String    @db.VarChar(20)
  direction     String    @default("LONG") @db.VarChar(5)
  entryPrice    Float
  /// Catastrophe stop (LIVE safety net — the backtest had no stop). Wide; the real
  /// exits are the +tpPct TP and the exitHour force-close.
  stopLoss      Float
  takeProfit    Float
  keyValue      Float     @default(1)
  /// |entry − UTBot line| / entry × 100, captured at entry (the M30 trend distance).
  entryLineDistancePct Float?
  quantity      Float?
  positionValue Float?
  /// ACTIVE | TP_HIT | SL_HIT | FORCE_CLOSE | MANUAL_CLOSE | FAILED
  status        String    @db.VarChar(20)
  mode          String    @default("PAPER") @db.VarChar(10)
  /// Bitget order id returned when a LIVE order is placed; null in PAPER mode.
  brokerOrderId String?   @db.VarChar(64)
  closedPrice   Float?
  closedAt      DateTime?
  pnlUsd        Float?
  setupJson     String    @db.Text
  note          String?   @db.Text
  detectedAt    DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([symbol, status, detectedAt])
  @@map("long_signals")
}

model LongSignalSettings {
  id                 String   @id @default("singleton")
  /// Fixed USD notional opened per coin per day (no compounding).
  /// Default $50 → at 5x leverage that is ~$10 margin per order.
  notional           Float    @default(50)
  keyValue           Float    @default(1)
  atrPeriod          Int      @default(10)
  /// Take-profit percent above entry (e.g. 2 = +2%).
  tpPct              Float    @default(2)
  /// Wide catastrophe stop percent below entry (LIVE safety net).
  catastropheStopPct Float    @default(5)
  /// Entry hour UTC (00:00 = best in backtest) and force-close hour UTC.
  entryHour          Int      @default(0)
  exitHour           Int      @default(8)
  leverage           Int      @default(5)
  /// Comma-separated basket traded by the bot.
  symbols            String   @default("POLUSDT,XRPUSDT,SOLUSDT,TAOUSDT") @db.VarChar(255)
  mode               String   @default("PAPER") @db.VarChar(10)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("long_signal_settings")
}

model SmallCapCoin {
  id          String           @id @default(cuid())
  symbol      String           @unique @db.VarChar(30)
  name        String           @default("") @db.VarChar(100)
  marketCap   Float?
  listingDate DateTime?        @db.Date
  addedAt     DateTime         @default(now())
  signals     SmallCapSignal[]
  signalHistory SmallCapSignalHistory[]

  @@map("small_cap_coins")
}

model SmallCapSignal {
  id             String       @id @default(cuid())
  coinId         String
  date           DateTime     @db.Date
  rsi            Float?
  volMultiplier  Float?
  ema34Above     Boolean      @default(false)
  ema89Above     Boolean      @default(false)
  ema200Above    Boolean      @default(false)
  stage          String       @default("Quiet") @db.VarChar(20)
  signalScore    Int          @default(0)
  extPct         Float?
  sparklineJson  String       @db.Text
  trend          String       @default("Neutral") @db.VarChar(15)
  swingStructure String       @default("Mixed") @db.VarChar(10)
  scannedAt      DateTime     @default(now())
  coin           SmallCapCoin @relation(fields: [coinId], references: [id], onDelete: Cascade)

  @@unique([coinId, date])
  @@index([date, signalScore(sort: Desc)])
  @@map("small_cap_signals")
}

// Append-only change log of the radar signal. A new row is written only when the
// stage (Breakout/Trending/Accumulating/Waking/Extended/Oversold/Quiet) differs from the
// most recent row for the coin — a compact history of stage transitions, not
// every daily scan.
model SmallCapSignalHistory {
  id            String       @id @default(cuid())
  coinId        String
  stage         String       @db.VarChar(20)
  signalScore   Int          @default(0)
  trend         String       @default("Neutral") @db.VarChar(15)
  rsi           Float?
  volMultiplier Float?
  extPct        Float?
  price         Float?
  scannedAt     DateTime     @default(now())
  coin          SmallCapCoin @relation(fields: [coinId], references: [id], onDelete: Cascade)

  @@index([coinId, scannedAt(sort: Desc)])
  @@map("small_cap_signal_history")
}

// ── Meme Radar ────────────────────────────────────────────────────────────────
// Parallel to SmallCap* but the universe is meme-category coins (CoinGecko
// category=meme-token) that are listed on Binance. Same daily D1 signal engine.
model MemeCoin {
  id          String       @id @default(cuid())
  symbol      String       @unique @db.VarChar(30)
  name        String       @default("") @db.VarChar(100)
  marketCap   Float?
  listingDate DateTime?    @db.Date
  addedAt     DateTime     @default(now())
  signals     MemeSignal[]
  signalHistory MemeSignalHistory[]

  @@map("meme_coins")
}

model MemeSignal {
  id             String   @id @default(cuid())
  coinId         String
  date           DateTime @db.Date
  rsi            Float?
  volMultiplier  Float?
  ema34Above     Boolean  @default(false)
  ema89Above     Boolean  @default(false)
  ema200Above    Boolean  @default(false)
  stage          String   @default("Quiet") @db.VarChar(20)
  signalScore    Int      @default(0)
  extPct         Float?
  sparklineJson  String   @db.Text
  trend          String   @default("Neutral") @db.VarChar(15)
  swingStructure String   @default("Mixed") @db.VarChar(10)
  scannedAt      DateTime @default(now())
  coin           MemeCoin @relation(fields: [coinId], references: [id], onDelete: Cascade)

  @@unique([coinId, date])
  @@index([date, signalScore(sort: Desc)])
  @@map("meme_signals")
}

// Append-only change log of the radar signal — a new row only when the stage
// differs from the most recent row for the coin.
model MemeSignalHistory {
  id            String   @id @default(cuid())
  coinId        String
  stage         String   @db.VarChar(20)
  signalScore   Int      @default(0)
  trend         String   @default("Neutral") @db.VarChar(15)
  rsi           Float?
  volMultiplier Float?
  extPct        Float?
  price         Float?
  scannedAt     DateTime @default(now())
  coin          MemeCoin @relation(fields: [coinId], references: [id], onDelete: Cascade)

  @@index([coinId, scannedAt(sort: Desc)])
  @@map("meme_signal_history")
}

model DcaLadderSettings {
  id            String   @id @default("singleton")
  symbol        String   @unique @default("BTCUSDT") @db.VarChar(20)
  startCapital  Float    @default(1000)
  firstTierPct  Float    @default(5)
  /// First tier % when the weekly trend is bear/neutral (deeper entry). Bull uses firstTierPct.
  bearFirstTierPct Float @default(10)
  numTiers      Int      @default(10)
  stepPct       Float    @default(1.5)
  tpPct         Float    @default(10)
  feePct        Float    @default(0.05)
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("dca_ladder_settings")
}

model DcaCycle {
  id           String    @id @default(cuid())
  symbol       String    @db.VarChar(20)
  cycleNumber  Int
  /// FLAT | IN_POSITION | CLOSED
  status       String    @db.VarChar(20)
  peak         Float
  budget       Float
  avgCost      Float?
  positionSize Float?
  tpPrice      Float?
  realizedPnl  Float?
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  orders       DcaOrder[]

  @@index([symbol, status])
  @@map("dca_cycles")
}

model DcaOrder {
  id           String    @id @default(cuid())
  cycleId      String
  cycle        DcaCycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  /// BUY | SELL
  side         String    @db.VarChar(4)
  /// 0..numTiers-1 for buys; null for the TP sell
  tierIndex    Int?
  plannedPrice Float
  fillPrice    Float?
  usdAmount    Float?
  qty          Float?
  /// ARMED | PENDING_FILL | FILLED | CANCELLED
  status       String    @db.VarChar(16)
  filledAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([cycleId, status])
  @@map("dca_orders")
}


// ── Spot Flip watchlist ───────────────────────────────────────────────────────
// The set of coins the user tracks on the /spot-flip page. A plain persisted
// watchlist (no signals/history) — the page still computes all metrics live from
// Binance on each view; this only remembers *which* coins to show.
model SpotFlipWatch {
  id         String    @id @default(cuid())
  symbol     String    @unique @db.VarChar(30)
  name       String    @default("") @db.VarChar(100)
  addedAt    DateTime  @default(now())
  // Soft-delete marker: non-null means the user removed the coin from the
  // watchlist. We keep the row (history/settings) and just hide it. Re-adding
  // the same symbol clears this back to null.
  disabledAt DateTime?

  @@map("spot_flip_watch")
}

// One daily spot-flip snapshot per coin, written by the worker cron at 00:15
// UTC. Stores the up/down ratio (dual-bar shares), the raw range/ATR metrics,
// and an auto-generated Vietnamese stance note, so the page can show a history
// of how each coin's position evolved day to day. Unique per (symbol, date).
model SpotFlipDaily {
  id          String   @id @default(cuid())
  symbol      String   @db.VarChar(30)
  date        DateTime @db.Date
  price       Float
  upPct       Float // % "tăng giá" — headroom to the 30d high
  downPct     Float // % "giảm giá" — downside to the 30d low
  pullbackPct Float
  reboundPct  Float
  atrPct      Float
  high30d     Float
  low30d      Float
  changeH24   Float?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([symbol, date])
  @@index([symbol])
  @@map("spot_flip_daily")
}

// Free-form manual logs/notes a user adds to a /spot-flip coin. Append-only:
// each save is a new timestamped entry (hh:mm:ss preserved via createdAt), so a
// coin accumulates a running journal. Content is Markdown (edited with the
// shared MarkdownEditor).
model SpotFlipLog {
  id        String   @id @default(cuid())
  symbol    String   @db.VarChar(30)
  content   String   @db.LongText
  createdAt DateTime @default(now())

  @@index([symbol])
  @@map("spot_flip_log")
}

// Watchlist for the /pattern-scanner page. Stateless scanner (no persisted signals):
// the user manages a coin list, then scans it on-demand for chart patterns.
model PatternWatchCoin {
  id      String   @id @default(cuid())
  symbol  String   @unique @db.VarChar(30)
  name    String   @default("") @db.VarChar(100)
  addedAt DateTime @default(now())

  @@map("pattern_watch_coins")
}

// Reference images attached to each pattern kind — real-world examples the user
// collects as study material (image URL + optional notes, no file upload needed).
model PatternReferenceImage {
  id        String   @id @default(cuid())
  pattern   String   @db.VarChar(30)
  imageUrl  String   @db.Text
  r2Key     String?  @db.VarChar(500)
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  @@index([pattern])
  @@map("pattern_reference_images")
}

// Watchlist for the /ema-bounce page — the EMA-stack oversold StochRSI bounce
// scanner. The worker auto-scans this list every 4h and persists matched signals.
model EmaStochWatchCoin {
  id      String           @id @default(cuid())
  symbol  String           @unique @db.VarChar(30)
  name    String           @default("") @db.VarChar(100)
  addedAt DateTime         @default(now())
  signals EmaStochSignal[]

  @@map("ema_stoch_watch_coins")
}

// A triggered signal "card": one long entry that satisfied the strategy on a closed
// 4h candle. Outcome-tracked — currentPrice/pnlPct refresh each scan; status goes
// open → hit_tp (price reached the +10% TP) or expired.
model EmaStochSignal {
  id            String            @id @default(cuid())
  coinId        String
  coin          EmaStochWatchCoin @relation(fields: [coinId], references: [id], onDelete: Cascade)
  symbol        String            @db.VarChar(30)
  timeframe     String            @default("4h") @db.VarChar(10) // scan timeframe: 4h | 1d
  triggeredAt   DateTime // the candle close time that produced the signal
  status        String            @default("open") @db.VarChar(20) // open | hit_tp | expired
  stage         String            @default("reach") @db.VarChar(10) // monitoring stage: near | reach | risk
  note          String?           @db.VarChar(255) // short reason / met conditions for the current stage
  score         Int               @default(0) // 0–100 weighted setup-completeness score
  htfTrend      String?           @db.VarChar(12) // higher-TF PA trend scored by the PA block: StrongUp | Up | Neutral | Down | StrongDown
  swingStructure String?          @db.VarChar(8) // entry-TF swing structure: HH_HL | HH_LL | LH_HL | LH_LL | Mixed
  entryPrice    Float
  tpPrice       Float
  distPct       Float // distance below EMA34 at entry (fraction, e.g. 0.093)
  rsi           Float?
  stochK        Float?
  stochD        Float?
  ema34         Float?
  ema89         Float?
  ema200        Float?
  currentPrice  Float?
  pnlPct        Float?
  hitTpAt       DateTime?
  lastCheckedAt DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([coinId, timeframe, triggeredAt])
  @@index([symbol])
  @@index([status])
  @@map("ema_stoch_signals")
}

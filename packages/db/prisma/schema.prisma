generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AnalysisRun {
  id               String            @id @default(cuid())
  symbol           String
  timeframe        String
  candleOpenTime   DateTime
  candleCloseTime  DateTime
  priceOpen        Float
  priceHigh        Float
  priceLow         Float
  priceClose       Float
  rawIndicatorsJson String           @db.Text
  llmInputJson     String            @db.Text
  llmOutputJson    String            @db.Text
  status           String
  errorMessage     String?           @db.Text
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  signal           Signal?
  telegramLogs     TelegramMessageLog[]

  @@unique([symbol, timeframe, candleCloseTime])
  @@index([symbol, timeframe, candleCloseTime])
}

model Signal {
  id                   String    @id @default(cuid())
  analysisRunId        String    @unique
  symbol               String
  timeframe            String
  trend                String
  bias                 String
  confidence           Int
  summary              String    @db.Text
  supportLevelsJson    String    @db.Text
  resistanceLevelsJson String    @db.Text
  invalidation         String    @db.Text
  bullishScenario      String    @db.Text
  bearishScenario      String    @db.Text
  createdAt            DateTime  @default(now())
  analysisRun          AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  orders               Order[]

  @@index([symbol, timeframe, createdAt])
}

model Order {
  id         String      @id @default(cuid())
  signalId   String?
  source     String
  symbol     String
  side       String
  entryPrice Float
  stopLoss   Float?
  takeProfit Float?
  quantity   Float?
  leverage   Float?
  exchange   String?
  status     String
  openedAt   DateTime
  closedAt   DateTime?
  closePrice Float?
  pnl        Float?
  note       String?     @db.Text
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  signal     Signal?     @relation(fields: [signalId], references: [id], onDelete: SetNull)

  @@index([symbol, status, openedAt])
}

model TelegramMessageLog {
  id            String              @id @default(cuid())
  analysisRunId String?
  chatId        String
  messageType   String
  content       String              @db.Text
  success       Boolean
  errorMessage  String?             @db.Text
  sentAt        DateTime
  createdAt     DateTime            @default(now())
  analysisRun   AnalysisRun?        @relation(fields: [analysisRunId], references: [id], onDelete: SetNull)
}

model DailyAnalysis {
  id        String   @id @default(cuid())
  symbol    String
  date      DateTime @db.Date
  d1Trend   String
  h4Trend   String
  d1S1      Float
  d1S2      Float
  d1R1      Float
  d1R2      Float
  h4S1      Float
  h4S2      Float
  h4R1      Float
  h4R2      Float
  summary   String   @db.Text
  createdAt DateTime @default(now())

  @@unique([symbol, date])
  @@index([symbol, date])
}

model Settings {
  id               String   @id @default(cuid())
  name             String
  trackingSymbols  Json     @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("settings")
}
